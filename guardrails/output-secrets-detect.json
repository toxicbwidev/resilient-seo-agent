{
  "name": "output-secrets-detect",
  "description": "Strip secrets (API keys, tokens, credentials) from LLM output before returning to client.",
  "type": "secrets_detection",
  "scope": "llm_output",
  "mode": "mutate",
  "enforcement_strategy": "enforce",
  "providers": [
    "truefoundry.builtin.secrets"
  ],
  "config": {
    "patterns": [
      {"name": "aws_access_key",  "regex": "AKIA[0-9A-Z]{16}"},
      {"name": "aws_secret_key",  "regex": "(?i)aws[_-]?secret[_-]?access[_-]?key[\"'\\s:=]+[A-Za-z0-9/+=]{40}"},
      {"name": "github_pat",      "regex": "gh[pousr]_[A-Za-z0-9]{36,}"},
      {"name": "slack_bot_token", "regex": "xox[baprs]-[A-Za-z0-9-]+"},
      {"name": "openai_api_key",  "regex": "sk-[A-Za-z0-9]{32,}"},
      {"name": "anthropic_key",   "regex": "sk-ant-[A-Za-z0-9-]{20,}"},
      {"name": "private_key_pem", "regex": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"}
    ],
    "replacement": "<REDACTED:{name}>",
    "block_if_any_match": false,
    "audit_original": true
  },
  "rationale": "The model may regurgitate secrets it has been trained on or that were leaked into context via a prior tool call. Stripping at the gateway is the last line of defence before the agent's output reaches a downstream system (CMS, GitHub, email)."
}
