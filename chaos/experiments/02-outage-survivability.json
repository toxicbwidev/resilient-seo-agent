{
  "version": "1.0.0",
  "title": "outage-survivability",
  "description": "Inject provider outages (HTTP 503) on 8% of calls. The retry budget should still get most pipelines through; state must be intact even for the ones that abort.",
  "tags": ["outage", "circuit-breaker", "retry"],
  "steady_state_hypothesis": {
    "title": "Most pipelines complete under 8% outage rate; state intact across the board",
    "probes": [
      {
        "name": "completion_rate",
        "type": "metric",
        "tolerance": {"min": 0.65, "max": 1.0}
      },
      {
        "name": "state_integrity_rate",
        "type": "metric",
        "tolerance": {"min": 1.0, "max": 1.0}
      },
      {
        "name": "crash_rate",
        "type": "metric",
        "tolerance": {"min": 0.0, "max": 0.0}
      }
    ]
  },
  "method": [
    {
      "name": "inject-outages",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaos.injectors",
        "func": "outage_chaos",
        "arguments": {
          "n_pipelines": 50,
          "probability": 0.08,
          "seed": 42,
          "concurrency": 4
        }
      }
    }
  ],
  "rollbacks": []
}
