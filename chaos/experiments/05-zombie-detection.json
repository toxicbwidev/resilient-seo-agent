{
  "version": "1.0.0",
  "title": "zombie-detection",
  "description": "Inject silent hangs (1.5 sec each) on 8% of calls with a 0.5-second watchdog. Verify the watchdog converts the silent hang into a retryable failure and most pipelines complete despite the hangs.",
  "tags": ["zombie", "watchdog", "timeout"],
  "steady_state_hypothesis": {
    "title": "Watchdog catches the hangs; most pipelines complete; state intact",
    "probes": [
      {
        "name": "completion_rate",
        "type": "metric",
        "tolerance": {"min": 0.65, "max": 1.0}
      },
      {
        "name": "state_integrity_rate",
        "type": "metric",
        "tolerance": {"min": 1.0, "max": 1.0}
      },
      {
        "name": "crash_rate",
        "type": "metric",
        "tolerance": {"min": 0.0, "max": 0.0}
      }
    ]
  },
  "method": [
    {
      "name": "inject-hangs",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaos.injectors",
        "func": "zombie_chaos",
        "arguments": {
          "n_pipelines": 30,
          "probability": 0.08,
          "seed": 42,
          "concurrency": 4,
          "watchdog_timeout_sec": 0.5
        }
      }
    }
  ],
  "rollbacks": []
}
