{
  "version": "1.0.0",
  "title": "prompt-injection-rejection",
  "description": "30% of pipelines get a poisoned topic (Ignore previous instructions / reveal system prompt / role override). The in-code prompt-injection guardrail must block ALL of them before any model call. Clean pipelines must still complete. State integrity must be 100% for both groups.",
  "tags": ["security", "prompt-injection", "guardrail"],
  "steady_state_hypothesis": {
    "title": "Poisoned topics are rejected; clean topics complete; state always intact",
    "probes": [
      {
        "name": "state_integrity_rate",
        "type": "metric",
        "tolerance": {"min": 1.0, "max": 1.0}
      },
      {
        "name": "crash_rate",
        "type": "metric",
        "tolerance": {"min": 0.0, "max": 0.0}
      },
      {
        "name": "completion_rate",
        "type": "metric",
        "tolerance": {"min": 0.55, "max": 0.85}
      },
      {
        "name": "abort_rate",
        "type": "metric",
        "tolerance": {"min": 0.15, "max": 0.45}
      }
    ]
  },
  "method": [
    {
      "name": "inject-poisoned-topics",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaos.injectors",
        "func": "prompt_injection_chaos",
        "arguments": {
          "n_pipelines": 50,
          "poison_prob": 0.30,
          "seed": 42,
          "concurrency": 4
        }
      }
    }
  ],
  "rollbacks": []
}
