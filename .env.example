# TrueFoundry AI Gateway
TFY_HOST=https://toxicbwi.truefoundry.cloud
TFY_API_KEY=

# AWS Bedrock (used by TrueFoundry — agent itself talks to TF gateway only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Pipeline config
PIPELINE_STATE_DIR=.session_state
CHECKPOINT_DIR=checkpoints
EVENT_LOG_PATH=event_log.jsonl

# Failure injection (for demo/testing, set to 1 to enable)
FAILURE_INJECT_ENABLED=0
FAILURE_INJECT_SCENARIO=
